# ── Instagram / Meta ──────────────────────────────────────────
# Long-lived User Access Token from Meta Graph API Explorer
INSTAGRAM_ACCESS_TOKEN=

# Your Facebook Page ID (not the Page name)
INSTAGRAM_PAGE_ID=

# Instagram Business/Creator Account ID
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# App Secret from your Facebook Developer App → Settings → Basic
FACEBOOK_APP_SECRET=

# A string you invent — must match what you enter in the Facebook
# webhook dashboard as the "Verify Token"
WEBHOOK_VERIFY_TOKEN=my_secret_verify_token_change_me

# ── Database ───────────────────────────────────────────────────
# SQLite (default). Swap for postgres://... when ready.
DATABASE_URL=sqlite:///./app.db
